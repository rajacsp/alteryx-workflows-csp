# LLM Provider Configuration
# Options: ollama, openai, llama.cpp, gemini
LLM_PROVIDER=llama.cpp

# Ollama Configuration (if using ollama)
OLLAMA_MODEL=llama3.2:3b

# OpenAI Configuration (if using openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Configuration (if using gemini)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# llama.cpp server URL (if using llama.cpp)
LLAMA_CPP_URL=http://127.0.0.1:8080/v1

# LLM Enhancement for Workflow Conversion
# Set to 'true' to enable LLM-based enhancement between Alteryx->MD and MD->Airflow steps
# When enabled, LLM will optimize and enhance the markdown documentation before conversion to Airflow
ENABLE_LLM_ENHANCEMENT=false
